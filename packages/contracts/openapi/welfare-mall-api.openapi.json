            "description": "Submit a saved merchant product draft for review",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "productId": "product-001",
                    "action": "submit_review",
                    "fromStatus": "draft",
                    "toStatus": "pending_review",
                    "reviewLog": {
                      "id": "review-log-001",
                      "productId": "product-001",
                      "actorUserId": "merchant-user-001",
