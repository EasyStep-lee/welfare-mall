<view class="page">
  <view class="summary">
    <text class="eyebrow">订单</text>
    <text class="title">我的订单</text>
    <text class="meta">{{orderDisplays.length}} 个订单</text>
  </view>

  <view wx:if="{{loading}}" class="state-text">加载中</view>
  <view wx:elif="{{error}}" class="state-text error">{{error}}</view>
  <view wx:elif="{{orderDisplays.length === 0}}" class="state-text">暂无订单</view>

  <view wx:else class="order-list">
    <view
      wx:for="{{orderDisplays}}"
      wx:key="orderNo"
      class="order-card"
      data-order-no="{{item.orderNo}}"
      bindtap="openOrderDetail"
    >
      <view class="order-card-header">
        <text class="order-no">{{item.orderNo}}</text>
        <text class="status">{{item.statusText}}</text>
      </view>
      <text class="line-name">{{item.firstLineName}}</text>
      <text wx:if="{{item.paymentText}}" class="payment-status">{{item.paymentText}}</text>
      <view class="order-card-footer">
        <text>{{item.lineCountText}}</text>
        <text class="total">{{item.totalText}}</text>
      </view>
    </view>
  </view>
</view>
