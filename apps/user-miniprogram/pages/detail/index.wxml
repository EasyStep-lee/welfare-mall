<view class="page">
  <view wx:if="{{loading}}" class="state-text">加载中</view>
  <view wx:elif="{{error}}" class="state-text error">{{error}}</view>

  <view wx:elif="{{detail}}" class="detail">
    <image class="hero-image" src="{{detail.displayImageUrl}}" mode="aspectFill" />
    <view class="header">
      <text class="title">{{detail.displayName}}</text>
      <text class="sku">{{detail.displaySkuCode || '默认规格'}}</text>
      <text class="price">{{priceText}}</text>
      <text class="origin">{{originText}}</text>
    </view>

    <view class="section">
      <text class="section-title">商品参数</text>
      <view wx:for="{{detail.product.parameters}}" wx:key="id" class="line">
        <text>{{item.name}}</text>
        <text>{{item.value}}</text>
      </view>
    </view>

    <view class="section">
      <text class="section-title">商品资质</text>
      <view wx:for="{{detail.product.qualifications}}" wx:key="title" class="line">
        <text>{{item.title}}</text>
        <text>{{item.certificateNo || '已上传'}}</text>
      </view>
    </view>

    <view class="section">
      <text class="section-title">详情说明</text>
      <view wx:for="{{detail.product.detailSections}}" wx:key="sortOrder" class="detail-line">
        <text class="detail-title">{{item.title}}</text>
        <text>{{item.content}}</text>
      </view>
    </view>

    <view class="section checkout">
      <text class="section-title">下单信息</text>
      <label class="field">
        <text>数量</text>
        <input value="{{quantity}}" type="number" bindinput="onQuantityInput" />
      </label>
      <label class="field">
        <text>福利卡抵扣(分)</text>
        <input value="{{welfareCardPaymentAmount}}" type="number" bindinput="onWelfareAmountInput" />
      </label>
      <label class="field">
        <text>收货人</text>
        <input value="{{receiverName}}" bindinput="onReceiverNameInput" />
      </label>
      <label class="field">
        <text>手机号</text>
        <input value="{{receiverPhone}}" type="number" bindinput="onReceiverPhoneInput" />
      </label>
      <label class="field">
        <text>收货地址</text>
        <input value="{{receiverAddress}}" bindinput="onReceiverAddressInput" />
      </label>

      <button class="secondary-button" loading="{{previewingAmount}}" bindtap="refreshAmountPreview">预览金额</button>

      <view wx:if="{{previewText}}" class="preview-box">
        <view class="line">
          <text>订单合计</text>
          <text>{{previewText.totalText}}</text>
        </view>
        <view class="line">
          <text>福利卡抵扣</text>
          <text>{{previewText.welfareCardText}}</text>
        </view>
        <view class="line">
          <text>线上补差</text>
          <text>{{previewText.onlineRemainderText}}</text>
        </view>
      </view>

      <button class="primary-button" loading="{{creatingOrder}}" bindtap="submitOrder">提交订单</button>
      <view wx:if="{{createdOrder}}" class="order-result">
        <text>{{createdOrder.orderNo}}</text>
        <text>{{createdOrder.status}}</text>
      </view>
      <text wx:if="{{checkoutError}}" class="error">{{checkoutError}}</text>
    </view>

    <view class="section bind-card">
      <text class="section-title">绑定福利卡</text>
      <label class="field">
        <text>福利卡卡号</text>
        <input value="{{bindCardNo}}" bindinput="onBindCardNoInput" />
      </label>
      <label class="field">
        <text>福利卡绑定码</text>
        <input value="{{bindCode}}" bindinput="onBindCodeInput" />
      </label>
      <button class="secondary-button" loading="{{bindingCard}}" disabled="{{bindingCard}}" bindtap="submitBindWelfareCard">
        绑定福利卡
      </button>
      <text wx:if="{{bindCardMessage}}" class="success">{{bindCardMessage}}</text>
      <text wx:if="{{bindCardError}}" class="error">{{bindCardError}}</text>
    </view>
  </view>
</view>
