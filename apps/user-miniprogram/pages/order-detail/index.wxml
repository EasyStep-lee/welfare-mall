<view class="page">
  <view wx:if="{{loading}}" class="state-text">加载中</view>
  <view wx:elif="{{error}}" class="state-text error">{{error}}</view>

  <view wx:elif="{{orderDisplay}}" class="detail">
    <view class="section">
      <view class="header-line">
        <text class="order-no">{{orderDisplay.orderNo}}</text>
        <text class="status">{{orderDisplay.statusText}}</text>
      </view>
      <text class="total">{{orderDisplay.totalText}}</text>
      <button class="secondary-button" loading="{{refreshingOrder}}" disabled="{{refreshingOrder}}" bindtap="refreshOrderDetail">
        刷新订单状态
      </button>
    </view>

    <view class="section">
      <text class="section-title">支付拆分</text>
      <view class="line">
        <text>福利卡抵扣</text>
        <text>{{orderDisplay.welfareCardText}}</text>
      </view>
      <view class="line">
        <text>线上补差</text>
        <text>{{orderDisplay.onlineRemainderText}}</text>
      </view>
    </view>

    <view wx:if="{{orderDisplay.latestPaymentDisplay}}" class="section">
      <text class="section-title">最近支付单</text>
      <view class="line">
        <text>支付单号</text>
        <text>{{orderDisplay.latestPaymentDisplay.paymentNo}}</text>
      </view>
      <view class="line">
        <text>支付渠道</text>
        <text>{{orderDisplay.latestPaymentDisplay.channelText}}</text>
      </view>
      <view class="line">
        <text>支付状态</text>
        <text>{{orderDisplay.latestPaymentDisplay.statusText}}</text>
      </view>
    </view>

    <view wx:if="{{order.status === 'pending_payment'}}" class="section payment-action">
      <view wx:if="{{order.welfareCardPayableAmount > 0}}" class="welfare-account-box">
        <text class="section-title">选择福利卡账户</text>
        <text wx:if="{{welfareCardAccountsLoading}}" class="muted">福利卡账户加载中</text>
        <text wx:elif="{{welfareCardAccountsError}}" class="error">{{welfareCardAccountsError}}</text>
        <text wx:elif="{{welfareCardAccounts.length === 0}}" class="muted">暂无可用福利卡账户</text>
        <view wx:else class="account-list">
          <button
            wx:for="{{welfareCardAccounts}}"
            wx:key="id"
            class="secondary-button {{selectedWelfareCardAccountId === item.id ? 'active-channel' : ''}}"
            data-account-id="{{item.id}}"
            bindtap="selectWelfareCardAccount"
          >
            {{item.accountNo}} 余额 {{item.balanceAmount}}
          </button>
        </view>
      </view>
      <view class="channel-row">
        <button
          class="secondary-button {{selectedPaymentChannel === 'wechat' ? 'active-channel' : ''}}"
          data-channel="wechat"
          aria-label="选择微信支付渠道"
          bindtap="selectPaymentChannel"
        >
          微信支付
        </button>
        <button
          class="secondary-button {{selectedPaymentChannel === 'alipay' ? 'active-channel' : ''}}"
          data-channel="alipay"
          aria-label="选择支付宝支付渠道"
          bindtap="selectPaymentChannel"
        >
          支付宝
        </button>
      </view>
      <button class="primary-button" loading="{{creatingPayment}}" disabled="{{creatingPayment}}" bindtap="submitPayment">
        发起线上支付
      </button>
      <button wx:if="{{canCancelOrder}}" class="secondary-button danger-button" loading="{{cancellingOrder}}" disabled="{{cancellingOrder}}" bindtap="cancelOrder">
        取消订单
      </button>
      <view wx:if="{{paymentDisplay}}" class="payment-result">
        <view class="line">
          <text>支付单号</text>
          <text>{{paymentDisplay.paymentNo}}</text>
        </view>
        <view class="line">
          <text>支付渠道</text>
          <text>{{paymentDisplay.channelText}}</text>
        </view>
        <view class="line">
          <text>支付状态</text>
          <text>{{paymentDisplay.statusText}}</text>
        </view>
      </view>
      <text wx:if="{{paymentError}}" class="error">{{paymentError}}</text>
      <text wx:if="{{cancelError}}" class="error">{{cancelError}}</text>
    </view>

    <view wx:if="{{canRequestRefund || refundDisplay || orderDisplay.latestRefundDisplay}}" class="section refund-action">
      <button wx:if="{{canRequestRefund}}" class="secondary-button" loading="{{requestingRefund}}" disabled="{{requestingRefund}}" bindtap="submitRefund">
        申请售后退款
      </button>
      <view wx:if="{{orderDisplay.latestRefundDisplay}}" class="payment-result">
        <view class="line">
          <text>最近退款单号</text>
          <text>{{orderDisplay.latestRefundDisplay.refundNo}}</text>
        </view>
        <view class="line">
          <text>退款渠道</text>
          <text>{{orderDisplay.latestRefundDisplay.channelText}}</text>
        </view>
        <view class="line">
          <text>退款金额</text>
          <text>{{orderDisplay.latestRefundDisplay.refundAmountText}}</text>
        </view>
        <view class="line">
          <text>退款状态</text>
          <text>{{orderDisplay.latestRefundDisplay.statusText}}</text>
        </view>
      </view>
      <view wx:if="{{refundDisplay}}" class="payment-result">
        <view class="line">
          <text>退款单号</text>
          <text>{{refundDisplay.refundNo}}</text>
        </view>
        <view class="line">
          <text>退款渠道</text>
          <text>{{refundDisplay.channelText}}</text>
        </view>
        <view class="line">
          <text>退款金额</text>
          <text>{{refundDisplay.refundAmountText}}</text>
        </view>
        <view class="line">
          <text>退款状态</text>
          <text>{{refundDisplay.statusText}}</text>
        </view>
      </view>
      <text wx:if="{{refundError}}" class="error">{{refundError}}</text>
    </view>

    <view class="section">
      <text class="section-title">收货信息</text>
      <text class="muted">{{orderDisplay.receiverText}}</text>
      <view wx:if="{{orderDisplay.pickupCodeText}}" class="line pickup-code-line">
        <text>取货码</text>
        <text class="pickup-code">{{orderDisplay.pickupCodeText}}</text>
      </view>
    </view>

    <view class="section">
      <text class="section-title">商品明细</text>
      <view wx:for="{{orderDisplay.lines}}" wx:key="id" class="order-line">
        <text class="line-name">{{item.displayName}}</text>
        <text class="muted">{{item.skuText}} {{item.quantityText}}</text>
        <view class="line">
          <text>{{item.unitPriceText}}</text>
          <text>{{item.lineTotalText}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
