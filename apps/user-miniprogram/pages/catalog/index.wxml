<view class="page">
  <view class="summary">
    <text class="eyebrow">商品池</text>
    <text class="title">福利商品浏览</text>
    <text class="meta">{{items.length}} 个可选商品</text>
  </view>

  <view wx:if="{{loading}}" class="state-text">加载中</view>
  <view wx:elif="{{error}}" class="state-text error">{{error}}</view>
  <view wx:elif="{{items.length === 0}}" class="state-text">暂无可展示商品</view>

  <view wx:else class="product-list">
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="product-card"
      data-item-id="{{item.id}}"
      bindtap="openDetail"
    >
      <image class="product-image" src="{{item.displayImageUrl}}" mode="aspectFill" />
      <view class="product-info">
        <text class="product-name">{{item.displayName}}</text>
        <text class="product-sku">{{item.displaySkuCode || '默认规格'}}</text>
        <text class="product-pool">{{item.poolName}}</text>
        <text class="product-price">{{item.priceText}}</text>
      </view>
    </view>
  </view>
</view>
