.page {
  padding: 24rpx;
}

.summary {
  background: #ffffff;
  border: 1rpx solid #d7e1dd;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.eyebrow,
.meta,
.product-sku,
.product-pool {
  color: #5c7177;
  font-size: 24rpx;
}

.title {
  color: #172026;
  font-size: 38rpx;
  font-weight: 700;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.product-card {
  background: #ffffff;
  border: 1rpx solid #d7e1dd;
  border-radius: 16rpx;
  display: flex;
  gap: 20rpx;
  overflow: hidden;
  padding: 16rpx;
}

.product-image {
  background: #eef3f1;
  border-radius: 12rpx;
  height: 180rpx;
  width: 180rpx;
}

.product-info {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.product-name {
  color: #172026;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
}

.product-price {
  color: #9c3f22;
  font-size: 34rpx;
  font-weight: 700;
  margin-top: auto;
}

.error {
  color: #9c2d20;
}
