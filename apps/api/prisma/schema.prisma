generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SystemMigrationMarker {
  id        String   @id @default(cuid())
  marker    String   @unique
  createdAt DateTime @default(now())

  @@map("system_migration_marker")
}

model Region {
  id         String      @id @default(cuid())
  code       String      @unique
  name       String
  level      String
  parentId   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?
  parent     Region?     @relation("RegionHierarchy", fields: [parentId], references: [id])
  children   Region[]    @relation("RegionHierarchy")
  franchises Franchise[]
  merchants  Merchant[]

  @@index([parentId])
  @@index([level])
  @@map("region")
}

model Franchise {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  status    String
  regionId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  region    Region?    @relation(fields: [regionId], references: [id])
  merchants Merchant[]
  products  Product[]
  productPools ProductPool[]

  @@index([regionId])
  @@index([status])
  @@map("franchise")
}

model Merchant {
  id             String    @id @default(cuid())
  code           String    @unique
  name           String
  status         String
  franchiseId    String
  regionId       String?
  businessScopes Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  franchise      Franchise @relation(fields: [franchiseId], references: [id])
  region         Region?   @relation(fields: [regionId], references: [id])
  products       Product[]

  @@index([franchiseId])
  @@index([regionId])
  @@index([status])
  @@map("merchant")
}

model ProductCategory {
  id         String                 @id @default(cuid())
  code       String                 @unique
  name       String
  parentId   String?
  sortOrder  Int                    @default(0)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  deletedAt  DateTime?
  parent     ProductCategory?       @relation("ProductCategoryHierarchy", fields: [parentId], references: [id])
  children   ProductCategory[]      @relation("ProductCategoryHierarchy")
  products   Product[]
  specTemplates ProductSpecTemplate[]

  @@index([parentId])
  @@map("product_category")
}

model ProductBrand {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  logoUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  products  Product[]

  @@map("product_brand")
}

model ProductSpecTemplate {
  id         String                 @id @default(cuid())
  code       String                 @unique
  name       String
  categoryId String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  deletedAt  DateTime?
  category   ProductCategory?       @relation(fields: [categoryId], references: [id])
  attributes ProductSpecAttribute[]

  @@index([categoryId])
  @@map("product_spec_template")
}

model ProductSpecAttribute {
  id         String              @id @default(cuid())
  templateId String
  code       String
  name       String
  sortOrder  Int                 @default(0)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  template   ProductSpecTemplate @relation(fields: [templateId], references: [id])
  values     ProductSpecValue[]

  @@unique([templateId, code])
  @@index([templateId])
  @@map("product_spec_attribute")
}

model ProductSpecValue {
  id          String               @id @default(cuid())
  attributeId String
  code        String
  value       String
  sortOrder   Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  attribute   ProductSpecAttribute @relation(fields: [attributeId], references: [id])

  @@unique([attributeId, code])
  @@index([attributeId])
  @@map("product_spec_value")
}

model Product {
  id                 String                 @id @default(cuid())
  code               String                 @unique
  name               String
  merchantId         String
  franchiseId        String
  categoryId         String
  brandId            String?
  status             String
  saleStatus         String
  originCountry      String
  originProvince     String?
  originCity         String?
  originDescription  String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  deletedAt          DateTime?
  merchant           Merchant               @relation(fields: [merchantId], references: [id])
  franchise          Franchise              @relation(fields: [franchiseId], references: [id])
  category           ProductCategory        @relation(fields: [categoryId], references: [id])
  brand              ProductBrand?          @relation(fields: [brandId], references: [id])
  skus               ProductSku[]
  media              ProductMedia[]
  qualifications     ProductQualification[]
  parameters         ProductParameter[]
  detailSections     ProductDetailSection[]
  productPoolItems   ProductPoolItem[]
  draftSnapshots     ProductDraftSnapshot[]
  reviewLogs         ProductReviewLog[]

  @@index([merchantId])
  @@index([franchiseId])
  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([saleStatus])
  @@map("product")
}

model ProductDraftSnapshot {
  id        String   @id @default(cuid())
  productId String
  versionNo Int
  payload   Json
  createdBy String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([productId, versionNo])
  @@index([productId])
  @@map("product_draft_snapshot")
}

model ProductReviewLog {
  id          String   @id @default(cuid())
  productId   String
  actorUserId String?
  actorType   String
  action      String
  fromStatus  String
  toStatus    String
  reason      String?
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([actorUserId])
  @@index([action])
  @@map("product_review_log")
}

model ProductSku {
  id                 String            @id @default(cuid())
  productId          String
  code               String            @unique
  priceAmount        Int
  marketPriceAmount  Int
  costPriceAmount    Int?
  barcode            String?
  specs              Json
  weightGrams        Int?
  volumeMilliliters  Int?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  product            Product           @relation(fields: [productId], references: [id])
  productPoolItems   ProductPoolItem[]

  @@index([productId])
  @@map("product_sku")
}

model ProductMedia {
  id        String   @id @default(cuid())
  productId String
  type      String
  url       String
  sortOrder Int      @default(0)
  altText   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([type])
  @@map("product_media")
}

model ProductQualification {
  id            String    @id @default(cuid())
  productId     String
  type          String
  title         String
  certificateNo String?
  fileUrl       String?
  validFrom     DateTime?
  validTo       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  product       Product   @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([type])
  @@map("product_qualification")
}

model ProductParameter {
  id        String   @id @default(cuid())
  productId String
  groupName String
  name      String
  value     String
  valueType String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([valueType])
  @@map("product_parameter")
}

model ProductDetailSection {
  id        String   @id @default(cuid())
  productId String
  type      String
  title     String?
  content   String?
  imageUrl  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([type])
  @@map("product_detail_section")
}

model ProductPool {
  id          String                @id @default(cuid())
  code        String                @unique
  name        String
  status      String
  franchiseId String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  deletedAt   DateTime?
  franchise   Franchise?            @relation(fields: [franchiseId], references: [id])
  items       ProductPoolItem[]
  snapshots   ProductPoolSnapshot[]

  @@index([franchiseId])
  @@index([status])
  @@map("product_pool")
}

model ProductPoolItem {
  id                 String      @id @default(cuid())
  productPoolId      String
  productId          String
  skuId              String?
  sortOrder          Int         @default(0)
  displayName        String
  displaySkuCode     String?
  displayPriceAmount Int
  displayImageUrl    String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  productPool        ProductPool @relation(fields: [productPoolId], references: [id])
  product            Product     @relation(fields: [productId], references: [id])
  sku                ProductSku? @relation(fields: [skuId], references: [id])

  @@index([productPoolId])
  @@index([productId])
  @@index([skuId])
  @@map("product_pool_item")
}

model ProductPoolSnapshot {
  id            String      @id @default(cuid())
  productPoolId String
  snapshotNo    String      @unique
  status        String
  payload       Json
  createdAt     DateTime    @default(now())
  productPool   ProductPool @relation(fields: [productPoolId], references: [id])

  @@index([productPoolId])
  @@index([status])
  @@map("product_pool_snapshot")
}

model OrderState {
  id                String    @id @default(cuid())
  orderNo           String    @unique
  status            String
  paidAt            DateTime?
  refundRequestedAt DateTime?
  refundedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@map("order_state")
}

model OrderHeader {
  id                       String      @id @default(cuid())
  orderNo                  String      @unique
  requestId                String      @unique
  buyerUserId              String
  status                   String
  subtotalAmount           Int
  discountAmount           Int
  totalAmount              Int
  welfareCardPayableAmount Int
  cashPayableAmount        Int
  fulfillmentType          String
  receiverName             String?
  receiverPhone            String?
  receiverAddress          String?
  pickupStoreName          String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  lines                    OrderLine[]

  @@index([buyerUserId])
  @@index([status])
  @@map("order_header")
}

model OrderLine {
  id                String      @id @default(cuid())
  orderId           String
  productPoolItemId String
  productId         String
  skuId             String?
  displayName       String
  displaySkuCode    String?
  displayImageUrl   String
  unitPriceAmount   Int
  quantity          Int
  lineTotalAmount   Int
  createdAt         DateTime    @default(now())
  order             OrderHeader @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([productPoolItemId])
  @@index([productId])
  @@index([skuId])
  @@map("order_line")
}

model OrderPayment {
  id                       String                 @id @default(cuid())
  paymentNo                String                 @unique
  requestId                String                 @unique
  orderNo                  String
  status                   String
  channel                  String
  totalAmount              Int
  welfareCardPayableAmount Int
  cashPayableAmount        Int
  providerPaymentNo        String?
  paidAt                   DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  callbacks                OrderPaymentCallback[]

  @@index([orderNo])
  @@index([status])
  @@map("order_payment")
}

model OrderPaymentCallback {
  id                String       @id @default(cuid())
  paymentId         String
  paymentNo         String
  providerEventId   String       @unique
  providerPaymentNo String?
  status            String
  payload           Json
  createdAt         DateTime     @default(now())
  payment           OrderPayment @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([paymentNo])
  @@index([status])
  @@map("order_payment_callback")
}

model OrderRefund {
  id               String                @id @default(cuid())
  refundNo         String                @unique
  requestId        String                @unique
  paymentNo        String
  orderNo          String
  status           String
  channel          String
  refundAmount     Int
  reason           String
  providerRefundNo String?
  succeededAt      DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  callbacks        OrderRefundCallback[]

  @@index([paymentNo])
  @@index([orderNo])
  @@index([status])
  @@map("order_refund")
}

model OrderRefundCallback {
  id               String      @id @default(cuid())
  refundId         String
  refundNo         String
  providerEventId  String      @unique
  providerRefundNo String?
  status           String
  payload          Json
  createdAt        DateTime    @default(now())
  refund           OrderRefund @relation(fields: [refundId], references: [id])

  @@index([refundId])
  @@index([refundNo])
  @@index([status])
  @@map("order_refund_callback")
}

model IamUser {
  id        String        @id @default(cuid())
  username  String        @unique
  displayName String
  subjectType String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  roles     IamUserRole[]
  auditLogs IamAuditLog[]

  @@map("iam_user")
}

model IamRole {
  id          String              @id @default(cuid())
  code        String              @unique
  name        String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  users       IamUserRole[]
  permissions IamRolePermission[]

  @@map("iam_role")
}

model IamPermission {
  id        String              @id @default(cuid())
  code      String              @unique
  name      String
  risk      String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  roles     IamRolePermission[]

  @@map("iam_permission")
}

model IamUserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      IamUser  @relation(fields: [userId], references: [id])
  role      IamRole  @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("iam_user_role")
}

model IamRolePermission {
  id           String        @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime      @default(now())
  role         IamRole       @relation(fields: [roleId], references: [id])
  permission   IamPermission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("iam_role_permission")
}

model IamAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorType   String
  action      String
  targetType  String
  targetId    String
  reason      String
  risk        String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       IamUser? @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@map("iam_audit_log")
}

